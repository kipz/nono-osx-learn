{
  "meta": {
    "name": "mediation-demo",
    "version": "1.0",
    "description": "Demonstrates phantom token credential brokering"
  },
  "filesystem": {
    "read": [
      "/usr",
      "/bin",
      "/private/tmp/nono-demo",
      "/System",
      "/Library/Developer/CommandLineTools",
      "/nix"
    ],
    "allow": [
      "/private/tmp/nono-demo"
    ]
  },
  "mediation": {
    "env": {
      "block": ["GH_TOKEN", "GITHUB_TOKEN"]
    },
    "commands": [
      {
        "name": "ddtool",
        "intercept": [
          {
            "args_prefix": ["auth", "github", "token"],
            "action": { "type": "capture" }
          }
        ]
      }
    ]
  }
}
